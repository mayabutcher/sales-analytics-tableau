    <worksheet name='Sales to Profit Scatterplot Maya Butcher'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#666666'>Sales to Profit</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Arial' fontsize='10'>Chart Type</run>
            <run fontcolor='#000000' fontname='Arial' fontsize='10'>: Scatterplot</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Arial' fontsize='10'>Dual Axis</run>
            <run fontcolor='#000000' fontname='Arial' fontsize='10'>: N</run>
