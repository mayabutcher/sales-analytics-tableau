            <zone h='3423' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='4253' />
            <zone h='84440' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='14730'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Total sales and profit from June 2018 to December 2020.' captured-sheet='Profit and Sales Dual Axis Chart' id='1'>
                    <capturedDeltas>
                      <worksheet name='Profit and Sales Dual Axis Chart'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <format attr='title' class='0' field='[federated.144cbih02ubec814et9ro0e3acms].[sum:Calculation_361132396280385537:qk]' scope='rows' value='$ Sales' />
                            <format attr='title' class='0' field='[federated.144cbih02ubec814et9ro0e3acms].[sum:Calculation_361132396280893443:qk]' scope='rows' value='$ Profit' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Returning customers with a decreased order count.' captured-sheet='Customer Order Count Maya Butcher' id='3' />
                  <story-point caption='Profit by category gives insight into the bestsellers.' captured-sheet='Profit by Category Bar Chart Maya Butcher' id='2' />
                  <story-point caption='A broad perspective of category profitability.' captured-sheet='Sales vs. Profit by Category Maya Butcher' id='5' />
                  <story-point caption='2020 Sales Teams exceeded or nearly met their annual goal.' captured-sheet='Sales team 2020 Goals Maya Butcher' id='6' />
                  <story-point caption='How do Sales Channels rank?' captured-sheet='Profit by Sales Channel Maya Butcher' id='7' />
                  <story-point caption='How do Regions rank in terms of profitability?' captured-sheet='Profit by Region Maya Butcher' id='8'>
                    <capturedDeltas>
                      <worksheet name='Profit by Region Maya Butcher'>
                        <filter class='categorical' column='[federated.144cbih02ubec814et9ro0e3acms].[yr:OrderDate:ok]'>
                          <groupfilter function='level-members' level='[yr:OrderDate:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Sales and Profit State Map' captured-sheet='Sales Map by State Maya Butcher' id='9'>
                    <capturedDeltas>
                      <worksheet name='Sales Map by State Maya Butcher'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.144cbih02ubec814et9ro0e3acms].[Latitude (generated)]' field-type='quantitative' max='7979767.325143436' min='-113849.93564851163' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.144cbih02ubec814et9ro0e3acms].[Longitude (generated)]' field-type='quantitative' max='-7011749.4912509471' min='-15369399.227444479' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Analysis Summary' captured-sheet='Company Sales Dashboard Maya Butcher' id='10'>
                    <capturedDeltas>
                      <worksheet name='Profit and Sales Dual Axis Chart'>
                        <filter class='categorical' column='[federated.144cbih02ubec814et9ro0e3acms].[yr:OrderDate:ok]'>
                          <groupfilter function='member' level='[yr:OrderDate:ok]' member='2020' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
