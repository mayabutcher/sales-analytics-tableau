            <run fontcolor='#000000' fontname='Arial' fontsize='10'>: 2 (Sales, Profit)</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Arial' fontsize='10'>Table Calculations</run>
            <run fontcolor='#000000' fontname='Arial' fontsize='10'>: 0</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Arial' fontsize='10'>LOD Calculations</run>
            <run fontcolor='#000000' fontname='Arial' fontsize='10'>: 0</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Arial' fontsize='10'>Mark Cards</run>
