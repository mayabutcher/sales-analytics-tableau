            <run fontname='Arial'>N</run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Arial'>Trend Line:</run>
            <run fontname='Arial'> N</run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Arial'>Calculated Fields: </run>
            <run fontname='Arial'>1 (Sales)</run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Arial'>Table Calculations: </run>
            <run fontname='Arial'>0</run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Arial'>LOD Calculations: </run>
